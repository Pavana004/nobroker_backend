# ============================================================================
# Server
# ============================================================================
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ============================================================================
# Database
# ============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nobroker_clone?schema=public"

# ============================================================================
# JWT
# ============================================================================
# Access token: short-lived, sent in Authorization header, kept in memory on
# the client (never localStorage — see docs/AUTH_STRATEGY.md).
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m

# Refresh token: long-lived, stored in an httpOnly, Secure, SameSite=strict
# cookie. Hashed copy stored server-side for revocation + rotation-reuse
# detection.
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRY=7d
REFRESH_TOKEN_COOKIE_NAME=refreshToken

# ============================================================================
# Bcrypt
# ============================================================================
BCRYPT_SALT_ROUNDS=12

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
INQUIRY_RATE_LIMIT_MAX=5

# ============================================================================
# Image Upload (Cloudinary — see docs/IMAGE_STRATEGY.md for rationale)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MAX_IMAGE_SIZE_MB=5
MAX_IMAGES_PER_PROPERTY=10
