// ============================================================================
// Prisma Schema — NoBroker-style Real Estate Platform
// ============================================================================
// Design principles:
// - UUID primary keys (non-sequential, safe to expose in URLs, avoids
//   enumeration attacks, and merges well in distributed/sharded setups later)
// - Explicit foreign keys with onDelete behavior chosen per relationship
// - Composite/partial indexes on columns that drive the search & filter APIs
// - Enums for controlled vocabularies (roles, property type, furnishing)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN // reserved for future admin dashboard — role middleware already supports it
}

enum PropertyType {
  APARTMENT
  VILLA
  INDEPENDENT_HOUSE
  PLOT
  COMMERCIAL
  PG_HOSTEL
}

enum FurnishingType {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  RENTED
  SOLD
}

enum InquiryStatus {
  PENDING
  CONTACTED
  CLOSED
}

// ---------------------------------------------------------------------------
// USERS
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  properties    Property[]
  inquiriesSent Inquiry[]      @relation("InquiriesSent")
  refreshTokens RefreshToken[]

  @@index([email])
  @@map("users")
}

// ---------------------------------------------------------------------------
// REFRESH TOKENS
// Stored server-side (hashed) so tokens can be revoked/rotated individually.
// A row per device/session enables "logout everywhere" and rotation-reuse
// detection (if a rotated-out token is replayed, we know it was stolen).
// ---------------------------------------------------------------------------

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash") // sha256 of the raw token, never store raw
  isRevoked   Boolean   @default(false) @map("is_revoked")
  replacedBy  String?   @map("replaced_by") // id of the token that rotated this one out
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// PROPERTIES
// ---------------------------------------------------------------------------

model Property {
  id          String        @id @default(uuid())
  ownerId     String        @map("owner_id")

  title       String
  description String        @db.Text
  price       Decimal       @db.Decimal(12, 2) // exact currency math, never Float
  city        String
  locality    String
  address     String
  latitude    Decimal?      @db.Decimal(9, 6)
  longitude   Decimal?      @db.Decimal(9, 6)

  propertyType PropertyType  @map("property_type")
  bedrooms     Int
  bathrooms    Int
  area         Decimal       @db.Decimal(10, 2) // sq. ft.
  furnishing   FurnishingType

  amenities   String[]      @default([]) // e.g. ["parking","lift","gym"]
  status      ListingStatus @default(ACTIVE)

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner    User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images   PropertyImage[]
  inquiries Inquiry[]

  // --- Indexes: every one of these backs a real query in the search API ---
  @@index([city])                                   // "search by city"
  @@index([propertyType])                            // filter by type
  @@index([price])                                   // budget filter + sort by price
  @@index([bedrooms])                                // filter by bedrooms
  @@index([createdAt])                               // sort newest/oldest, cursor pagination
  @@index([city, propertyType, price])                // composite: most common filter combo
  @@index([city, bedrooms, price])                    // "similar properties" query
  @@map("properties")
}

// ---------------------------------------------------------------------------
// PROPERTY IMAGES
// Only URLs are stored — actual binary lives in object storage (see README).
// A dedicated table (rather than a String[] column) lets us store per-image
// metadata (order, alt text) and keep the Property row lean.
// ---------------------------------------------------------------------------

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  url        String
  sortOrder  Int      @default(0) @map("sort_order")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

// ---------------------------------------------------------------------------
// INQUIRIES (Leads)
// ---------------------------------------------------------------------------

model Inquiry {
  id         String        @id @default(uuid())
  propertyId String        @map("property_id")
  senderId   String        @map("sender_id")
  message    String        @db.Text
  status     InquiryStatus @default(PENDING)
  createdAt  DateTime      @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sender   User     @relation("InquiriesSent", fields: [senderId], references: [id], onDelete: Cascade)

  // A user can only have ONE open inquiry per property — enforced at the DB
  // level, not just in application code, so it holds under concurrent requests.
  @@unique([propertyId, senderId], name: "unique_property_sender")
  @@index([propertyId])
  @@index([senderId])
  @@index([createdAt])
  @@map("inquiries")
}
